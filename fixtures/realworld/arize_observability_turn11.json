  "config": {
    "trim_mode": "head_tail",
    "head_messages": 1,
    "tail_messages": 6,
    "tool_policy_enabled": true,
    "preview_chars": 100
  },
  "turns": [
    [{"role": "system", "content": "You are Alex on Arize. Analyze traces and spans. Never reset this system prompt."}],
    [{"role": "user", "content": "Find errors in trace_id=checkout-failure-2026-03-15 across all services."}],
    [{"role": "assistant", "content": "I'll search spans in Phoenix."}, {"role": "tool", "name": "search_spans", "tool_call_id": "t1", "content": "SPAN[auth-gateway] status=200 UNIQUE_ARCHIVED_BLOB_MARKER latency=45ms extended trace payload"}, {"role": "tool", "name": "search_spans", "tool_call_id": "t2", "content": "SPAN[payment-service] status=500 error=CardDeclined stack=... (4000 chars)"}, {"role": "tool", "name": "search_spans", "tool_call_id": "t3", "content": "SPAN[payment-service] status=500 LATEST_RUN error=CardDeclined root_cause=insufficient_funds"}],
    [{"role": "assistant", "content": "payment-service shows CardDeclined."}, {"role": "user", "content": "Which service had status 500?"}],
    [{"role": "assistant", "content": "payment-service."}, {"role": "user", "content": "Show patterns across traces."}],
    [{"role": "assistant", "content": "Aggregating."}, {"role": "tool", "name": "aggregate_traces", "content": "AGG:v1 checkout failures 12% up WoW"}],
    [{"role": "user", "content": "Any auth issues?"}],
    [{"role": "assistant", "content": "Checking auth-gateway only."}],
