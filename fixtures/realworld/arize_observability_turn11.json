  "assertions": [
    {"after_turn": 3, "kind": "content_in_hot", "value": "LATEST_RUN", "description": "Latest span search kept in hot"},
    {"after_turn": 3, "kind": "content_recallable", "value": "auth-gateway", "description": "Older span dump in warm store"},
    {"after_turn": 11, "kind": "content_in_hot", "value": "checkout-failure-2026-03-15", "description": "Turn 11: head anchor recalls original trace_id (DeLucia pattern)"},
    {"after_turn": 11, "kind": "content_recallable", "value": "UNIQUE_ARCHIVED_BLOB_MARKER", "description": "Superseded span full blob in warm store (preview may appear in hot placeholder)"},
    {"after_turn": 11, "kind": "hot_chars_under", "value": 15000, "description": "Bounded hot context under practical limit"}
  ]
