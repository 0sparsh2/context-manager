  "primary_recommendation": {
    "name": "Hybrid: Context Manager core + provider compaction adapters + Mem0-first semantic memory",
    "why": [
      "Preserves deterministic in-session policy strengths already implemented",
      "Adds durable cross-session memory where baseline is currently weakest",
      "Avoids single-vendor lock-in via adapter architecture"
    ],
    "risk_controls": [
      "Feature flags for each memory/compaction backend",
      "Benchmark gates in CI for recall, latency, and token budgets",
      "Citation verification mode for recalled facts"
    ]
  },
  "fallback_recommendation": {
    "name": "LangGraph + Redis profile with Context Manager policies as middleware",
    "when_to_choose": [
      "Need production-ready persistence primitives quickly",
      "Team already invested in LangChain/LangGraph ecosystem"
    ],
    "tradeoff": "Less differentiated policy layer unless Context Manager remains explicit in prompt/context pipeline"
  },
  "top_gaps": [
    "Cross-session semantic memory absent",
    "No benchmark-grade efficacy harness in CI",
    "Limited memory observability and governance",
    "No provider-aware compaction abstraction",
    "No citation/freshness verification for recalled facts"
  ],
  "top_actions": [
