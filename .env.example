# NVIDIA NIM (OpenAI-compatible)
NVIDIA_API_KEY=nvapi-xxxxxxxx
NVIDIA_MODEL=deepseek-ai/deepseek-v4-flash
NVIDIA_NIM_API_BASE=https://integrate.api.nvidia.com/v1

# Run: context-manager demo --llm nim

# OpenAI (optional)
# OPENAI_API_KEY=sk-...

# Package overrides (optional; take precedence when set)
# CONTEXT_MANAGER_LLM_PROVIDER=nim
# CONTEXT_MANAGER_MODEL=
# CONTEXT_MANAGER_BASE_URL=
# CONTEXT_MANAGER_API_KEY=
# CONTEXT_MANAGER_TEMPERATURE=0.2
# CONTEXT_MANAGER_MAX_TOKENS=1024
